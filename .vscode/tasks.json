{
    "version": "2.0.0",
    "presentation": {
        "reveal": "silent",
        "revealProblems": "onProblem",
        "close": true
    },
    "problemMatcher": [],
    "tasks": [
        {
            "label": "LeetCode: Fetch Contest",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/bin/python3",
            "windows": {
                "command": "${workspaceFolder}/.venv/Scripts/python"
            },
            "args": ["${workspaceFolder}/scripts/lc.py", "${input:contest_url}"],
            "options": {
                "env": {
                    "LEETCODE_EDITOR": "code"
                }
            }
        },
        {
            "label": "LeetCode: Fetch Problem",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/bin/python3",
            "windows": {
                "command": "${workspaceFolder}/.venv/Scripts/python"
            },
            "args": ["${workspaceFolder}/scripts/lc.py", "${input:problem_url}"],
            "options": {
                "env": {
                    "LEETCODE_EDITOR": "code"
                }
            }
        },
        {
            "label": "LeetCode: Load",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/bin/python3",
            "windows": {
                "command": "${workspaceFolder}/.venv/Scripts/python"
            },
            "args": ["${workspaceFolder}/scripts/lc.py", "load", "${input:load_key}"]
        },
        {
            "label": "LeetCode: Sync",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/bin/python3",
            "windows": {
                "command": "${workspaceFolder}/.venv/Scripts/python"
            },
            "args": ["${workspaceFolder}/scripts/lc.py", "sync"]
        }
    ],
    "inputs": [
        {
            "id": "contest_url",
            "type": "promptString",
            "description": "Enter LeetCode contest URL:"
        },
        {
            "id": "problem_url",
            "type": "promptString",
            "description": "Enter LeetCode problem URL:"
        },
        {
            "id": "load_key",
            "type": "promptString",
            "description": "Enter key to load (e.g. 87, w157_Q2):"
        }
    ]
}
