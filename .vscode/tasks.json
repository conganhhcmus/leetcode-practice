{
    "version": "2.0.0",
    "presentation": {
        "reveal": "silent",
        "revealProblems": "onProblem",
        "close": true
    },
    "problemMatcher": [],
    "tasks": [
        {
            "label": "LeetCode: Generate Contest",
            "type": "shell",
            "command": "python3",
            "windows": {
                "command": "py"
            },
            "args": ["${workspaceFolder}/scripts/genc.py", "${input:contest_name}"],
            "options": {
                "env": {
                    "LEETCODE_EDITOR": "code"
                }
            }
        },
        {
            "label": "LeetCode: Generate Problem",
            "type": "shell",
            "command": "python3",
            "windows": {
                "command": "py"
            },
            "args": ["${workspaceFolder}/scripts/genp.py", "${input:problem_name}"],
            "options": {
                "env": {
                    "LEETCODE_EDITOR": "code"
                }
            }
        }
    ],
    "inputs": [
        {
            "id": "contest_name",
            "type": "promptString",
            "description": "Enter LeetCode contest:"
        },
        {
            "id": "problem_name",
            "type": "promptString",
            "description": "Enter LeetCode problem:"
        }
    ]
}
